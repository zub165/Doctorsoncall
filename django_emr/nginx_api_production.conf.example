# GoDaddy VPS — api.docsoncalls.com (HTTPS)
# 1) cd django_emr && python3 manage.py collectstatic --noinput
# 2) Adjust paths below, then include in sites-enabled and reload nginx.

upstream docsoncalls_api {
    server 127.0.0.1:8012;
}

server {
    listen 443 ssl http2;
    server_name api.docsoncalls.com;

    client_max_body_size 25M;

    # ssl_certificate /path/to/fullchain.pem;
    # ssl_certificate_key /path/to/privkey.pem;

    location /static/ {
        alias /var/www/django_emr/staticfiles/;
        expires 30d;
        add_header Cache-Control "public";
    }

    location /media/ {
        alias /var/www/django_emr/media/;
        expires 7d;
    }

    # EMR JSON API (auth, TomTom proxy at /api/tomtom/*, hospitals, …) → gunicorn :8012
    location /api/ {
        proxy_pass http://docsoncalls_api/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
    }

    location /admin/ {
        proxy_pass http://docsoncalls_api/admin/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://docsoncalls_api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
    }
}

server {
    listen 80;
    server_name api.docsoncalls.com;
    return 301 https://$host$request_uri;
}
